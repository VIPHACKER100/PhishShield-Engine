# PhishShield-Engine Environment Configuration
# Copy this file to .env and fill in production values.

# Database
POSTGRES_USER=phish
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=phish_db
DATABASE_URL=postgresql://phish:CHANGE_ME_IN_PRODUCTION@postgres:5432/phish_db

# Redis
REDIS_HOST=redis

# Auth
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# Environment
ENV=prod
